{
  "name": "JSON Pretty Print",
  "description": "Pretty JSON in browser window.",
  "version": "1.0.0",
  "manifest_version": 3,
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "permissions": [],
  "host_permissions": ["<all_urls>"]
}
